<Window
    x:Class="LanFileSync.WinUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid
        x:Name="RootLayout"
        Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <NavigationView
            x:Name="AppNavigation"
            Grid.Row="0"
            Header="{Binding CurrentPageTitle}"
            IsBackButtonVisible="Collapsed"
            IsSettingsVisible="False"
            PaneDisplayMode="Left"
            SelectionChanged="OnNavigationSelectionChanged">
            <NavigationView.MenuItems>
                <NavigationViewItem Content="Dashboard" Icon="Home" Tag="dashboard" />
                <NavigationViewItem Content="Serve" Icon="Folder" Tag="serve" />
                <NavigationViewItem Content="Sync" Icon="Sync" Tag="sync" />
                <NavigationViewItem Content="Logs" Icon="Document" Tag="logs" />
                <NavigationViewItem Content="Settings" Icon="Setting" Tag="settings" />
            </NavigationView.MenuItems>
            <Frame x:Name="ContentFrame" />
        </NavigationView>

        <Border
            Grid.Row="1"
            Margin="16,0,16,16"
            Padding="16,12"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="14">
            <Grid ColumnSpacing="18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Spacing="4">
                    <TextBlock FontWeight="SemiBold" Text="{Binding BackendAvailabilityText}" />
                    <TextBlock
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="{Binding BackendSummaryText}"
                        TextTrimming="CharacterEllipsis" />
                </StackPanel>

                <TextBlock
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    FontWeight="SemiBold"
                    Text="{Binding ServiceStateText}" />

                <TextBlock
                    Grid.Column="2"
                    VerticalAlignment="Center"
                    FontWeight="SemiBold"
                    Text="{Binding SyncStateText}" />
            </Grid>
        </Border>
    </Grid>
</Window>
