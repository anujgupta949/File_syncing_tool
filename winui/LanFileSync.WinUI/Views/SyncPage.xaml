<Page
    x:Class="LanFileSync.WinUI.Views.SyncPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer>
        <StackPanel Padding="24" Spacing="18">
            <Border
                Padding="20"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="18">
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Spacing="8">
                        <TextBlock FontSize="24" FontWeight="SemiBold" Text="Sync with a server" />
                        <TextBlock
                            x:Name="SyncStatusText"
                            FontWeight="SemiBold"
                            Text="No sync is running." />
                    </StackPanel>

                    <ProgressRing
                        x:Name="SyncProgressRing"
                        Grid.Column="1"
                        Width="30"
                        Height="30"
                        IsActive="False" />
                </Grid>
            </Border>

            <Border
                Padding="20"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="18">
                <StackPanel x:Name="SyncSettingsRoot" Spacing="14">
                    <TextBlock FontSize="20" FontWeight="SemiBold" Text="Client Settings" />

                    <TextBlock Text="Server Host or IP" />
                    <TextBox Text="{Binding LastServerHost, Mode=TwoWay}" />

                    <TextBlock Text="Local Folder" />
                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Text="{Binding LastSyncFolder, Mode=TwoWay}" />
                        <Button Grid.Column="1" Click="OnBrowseFolder" Content="Browse" />
                    </Grid>

                    <TextBlock Text="Port" />
                    <TextBox Text="{Binding DefaultPort, Mode=TwoWay}" />

                    <Button
                        x:Name="RunSyncButton"
                        Click="OnRunSync"
                        Content="Run Sync"
                        HorizontalAlignment="Left" />
                </StackPanel>
            </Border>

            <Border
                Padding="20"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="18">
                <StackPanel Spacing="8">
                    <TextBlock FontSize="20" FontWeight="SemiBold" Text="Command Preview" />
                    <TextBlock
                        x:Name="SyncCommandPreviewText"
                        FontFamily="Consolas"
                        TextWrapping="WrapWholeWords" />
                </StackPanel>
            </Border>

            <Border
                Padding="20"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="18">
                <StackPanel Spacing="10">
                    <TextBlock FontSize="20" FontWeight="SemiBold" Text="Live Logs" />
                    <ListView
                        x:Name="LogsList"
                        Height="320"
                        IsItemClickEnabled="False"
                        SelectionMode="None">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnSpacing="12" Padding="0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="70" />
                                        <ColumnDefinition Width="70" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock FontFamily="Consolas" Text="{Binding DisplayTime}" />
                                    <TextBlock Grid.Column="1" FontWeight="SemiBold" Text="{Binding Level}" />
                                    <TextBlock Grid.Column="2" Text="{Binding Message}" TextWrapping="WrapWholeWords" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
